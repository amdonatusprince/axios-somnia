# Public app configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOMNIA_RPC=https://dream-rpc.somnia.network/
NEXT_PUBLIC_SOMNIA_CHAIN_ID=50312
NEXT_PUBLIC_SUSDC_ADDRESS=0x94AA9A92A89F966B9d76cb28a5D6634f83c88709
NEXT_PUBLIC_COMPLIANCE_REGISTRY=0x40AD44798b7e37485C9132417CBffD3B7d72Ba0A
NEXT_PUBLIC_PAYROLL_TREASURY=0xC3f538638Ba74B0Aa407544fF8fC5BFc1F15262c
NEXT_PUBLIC_PAYROLL_BATCHER=0x84Abd8a18cb89B8f1ed79563Ad6984E02c5405D5
NEXT_PUBLIC_EMPLOYEE_REGISTRY=0x8a7447242C6dbF39c9DFDC5b71754Ea9bd022CFB
NEXT_PUBLIC_STREAM_VESTING=0x96638e8e4F074D7c2027590d09a16A416189285D
NEXT_PUBLIC_YIELD_ROUTER=0x0a7E689b9309c5a65ae354d14fd56B5e81f8CaF5
# Optional — only needed if you re-enable WalletConnect (QR / mobile). Injected-only mode ignores this.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Postgres URI for local CLI only (`pnpm db:schema`) — Supabase → Settings → Database → URI (direct :5432)
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_DB_PASSWORD@db.xxxx.supabase.co:5432/postgres

# Server-only app configuration
SESSION_JWT_SECRET=change_me_to_a_long_random_string
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
# Bridge: in development, mock is default (no real API). Use real sandbox on localhost: BRIDGE_USE_REAL_BRIDGE=true + valid BRIDGE_API_KEY.
# Force mock everywhere: BRIDGE_MOCK=true. Force real API in dev: BRIDGE_MOCK=false
# BRIDGE_MOCK=true
BRIDGE_API_KEY=your_bridge_api_key
BRIDGE_USE_REAL_BRIDGE=
BRIDGE_WEBHOOK_SECRET=your_bridge_webhook_secret
AXIOS_TREASURY_ADDRESS=0xYourFeeTreasuryWallet
AXIOS_AGENT_PRIVATE_KEY=0xYourServerAgentPrivateKey
RESEND_API_KEY=your_resend_api_key
CLAUDE_API_KEY=your_anthropic_api_key
STRIPE_SECRET_KEY=your_stripe_secret_key
ADMIN_USER_IDS=

# Local-only demo helpers
DEMO_EMPLOYER_ID=
DEMO_PAYROLL_RUN_ID=

# Contract deployment only (Somnia testnet — use 0x prefix)
DEPLOYER_PRIVATE_KEY=0xYourSomniaDeploymentPrivateKey
